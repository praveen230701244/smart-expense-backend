# Core
PORT=5000
DATA_DIR=./data
CORS_ORIGIN=http://localhost:5173
AUTH_DISABLED=true
DEV_USER_ID=dev-local
TESSERACT_CMD=/usr/bin/tesseract

# Firebase (set AUTH_DISABLED=false in production)
FIREBASE_PROJECT_ID=your-project-id

# Gemini (google-genai SDK; model in gemini_service.py)
GEMINI_API_KEY=
# Optional: use certifi CA bundle for SSL (default on)
GEMINI_USE_CERTIFI=true
# TEMP DEBUG ONLY — if ConnectTimeout persists, try true (insecure; do not use in prod)
GEMINI_DEBUG_INSECURE_SSL=false
# httpx read timeout (seconds) — raise if you see ReadTimeout waiting for Gemini
GEMINI_HTTP_READ_TIMEOUT=300
GEMINI_HTTP_CONNECT_TIMEOUT=60

# Optional: MiniLM embeddings (large deps — see requirements-ml.txt)
USE_MINILM=false

# Azure Blob (optional)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=
